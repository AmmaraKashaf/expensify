generator client {
  provider = "prisma-client-js"
}

// Run: npx ts-node --project prisma/tsconfig.json prisma/seed.ts

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ThemePreference {
  light
  dark
  system
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  cash
  card
  upi
  bank_transfer
  other
}

enum RecurringFrequency {
  daily
  weekly
  biweekly
  monthly
  quarterly
  yearly
}

enum BillingCycle {
  monthly
  quarterly
  yearly
}

enum ReminderRecurrence {
  once
  monthly
  quarterly
  yearly
}

enum SavingsContributionSource {
  manual
  auto_allocation
  transaction_link
}

enum FamilyMemberRole {
  admin
  member
}

enum ChatRole {
  user
  assistant
}

// ─── Core Tables ──────────────────────────────────────────────────────────────

model User {
  id                String          @id @default(uuid())
  email             String          @unique
  passwordHash      String?         @map("password_hash")
  displayName       String?         @map("display_name")
  avatarUrl         String?         @map("avatar_url")
  baseCurrency      String          @default("USD") @map("base_currency") @db.Char(3)
  themePreference   ThemePreference @default(system) @map("theme_preference")
  supabaseId        String?         @unique @map("supabase_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  categories            Category[]
  transactions          Transaction[]
  recurringConfigs      RecurringConfig[]
  budgets               Budget[]
  savingsGoals          SavingsGoal[]
  subscriptions         Subscription[]
  billReminders         BillReminder[]
  userAchievements      UserAchievement[]
  financialHealthScores FinancialHealthScore[]
  familyMemberships     FamilyMember[]
  createdFamilyGroups   FamilyGroup[]
  chatHistory           ChatHistory[]

  @@map("users")
}

model Category {
  id               String    @id @default(uuid())
  userId           String?   @map("user_id")
  name             String
  icon             String    @default("circle")
  colorHex         String    @default("#6B7280") @map("color_hex")
  parentCategoryId String?   @map("parent_category_id")
  isDefault        Boolean   @default(false) @map("is_default")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")

  user             User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentCategory   Category?    @relation("SubCategories", fields: [parentCategoryId], references: [id])
  subCategories    Category[]   @relation("SubCategories")
  transactions     Transaction[]
  recurringConfigs RecurringConfig[]
  budgets          Budget[]
  subscriptions    Subscription[]

  @@map("categories")
}

model Transaction {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  categoryId        String        @map("category_id")
  type              TransactionType
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @db.Char(3)
  convertedAmount   Decimal       @db.Decimal(12, 2) @map("converted_amount")
  description       String?
  merchantName      String?       @map("merchant_name")
  date              DateTime      @db.Date
  paymentMethod     PaymentMethod @default(other) @map("payment_method")
  tags              String[]      @default([])
  receiptUrl        String?       @map("receipt_url")
  isRecurring       Boolean       @default(false) @map("is_recurring")
  recurringConfigId String?       @map("recurring_config_id")
  notes             String?
  deletedAt         DateTime?     @map("deleted_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category        @relation(fields: [categoryId], references: [id])
  recurringConfig  RecurringConfig? @relation(fields: [recurringConfigId], references: [id])
  savingsContributions SavingsContribution[]
  paidBillReminders    BillReminder[]

  @@index([userId, date])
  @@index([userId, categoryId, date])
  @@index([userId, type, date])
  @@map("transactions")
}

model RecurringConfig {
  id           String             @id @default(uuid())
  userId       String             @map("user_id")
  categoryId   String             @map("category_id")
  type         TransactionType
  amount       Decimal            @db.Decimal(12, 2)
  currency     String             @db.Char(3)
  description  String?
  frequency    RecurringFrequency
  startDate    DateTime           @map("start_date") @db.Date
  endDate      DateTime?          @map("end_date") @db.Date
  nextOccurrence DateTime         @map("next_occurrence") @db.Date
  autoConfirm  Boolean            @default(false) @map("auto_confirm")
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@index([nextOccurrence, isActive])
  @@map("recurring_configs")
}

model Budget {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  categoryId         String?  @map("category_id")
  month              DateTime @db.Date
  amount             Decimal  @db.Decimal(12, 2)
  alertThreshold75   Boolean  @default(true) @map("alert_threshold_75")
  alertThreshold90   Boolean  @default(true) @map("alert_threshold_90")
  createdAt          DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId, month])
  @@unique([userId, categoryId, month])
  @@map("budgets")
}

model SavingsGoal {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  name                String
  targetAmount        Decimal  @db.Decimal(12, 2) @map("target_amount")
  currentAmount       Decimal  @default(0) @db.Decimal(12, 2) @map("current_amount")
  deadline            DateTime? @db.Date
  autoAllocatePercent Decimal?  @db.Decimal(5, 2) @map("auto_allocate_percent")
  icon                String   @default("piggy-bank")
  colorHex            String   @default("#10B981") @map("color_hex")
  isCompleted         Boolean  @default(false) @map("is_completed")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions SavingsContribution[]

  @@map("savings_goals")
}

model SavingsContribution {
  id            String                    @id @default(uuid())
  goalId        String                    @map("goal_id")
  amount        Decimal                   @db.Decimal(12, 2)
  source        SavingsContributionSource
  transactionId String?                   @map("transaction_id")
  date          DateTime                  @db.Date
  createdAt     DateTime                  @default(now()) @map("created_at")

  goal        SavingsGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@map("savings_contributions")
}

model Subscription {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  name              String
  categoryId        String      @map("category_id")
  amount            Decimal     @db.Decimal(12, 2)
  currency          String      @db.Char(3)
  billingCycle      BillingCycle @map("billing_cycle")
  nextBillingDate   DateTime    @db.Date @map("next_billing_date")
  reminderDaysBefore Int        @default(3) @map("reminder_days_before")
  isActive          Boolean     @default(true) @map("is_active")
  logoUrl           String?     @map("logo_url")
  notes             String?
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@map("subscriptions")
}

model BillReminder {
  id                String             @id @default(uuid())
  userId            String             @map("user_id")
  title             String
  amount            Decimal            @db.Decimal(12, 2)
  dueDate           DateTime           @db.Date @map("due_date")
  recurrence        ReminderRecurrence
  reminderOffsets   Int[]              @default([]) @map("reminder_offsets")
  isPaid            Boolean            @default(false) @map("is_paid")
  paidTransactionId String?            @map("paid_transaction_id")
  createdAt         DateTime           @default(now()) @map("created_at")

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  paidTransaction Transaction? @relation(fields: [paidTransactionId], references: [id])

  @@map("bill_reminders")
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model Achievement {
  id           String   @id @default(uuid())
  key          String   @unique
  title        String
  description  String
  icon         String
  points       Int      @default(0)
  criteriaJson Json     @map("criteria_json")

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ─── AI & Analytics ───────────────────────────────────────────────────────────

model FinancialHealthScore {
  id                      String   @id @default(uuid())
  userId                  String   @map("user_id")
  month                   DateTime @db.Date
  overallScore            Int      @map("overall_score")
  savingsRateScore        Int      @map("savings_rate_score")
  budgetAdherenceScore    Int      @map("budget_adherence_score")
  spendingConsistencyScore Int     @map("spending_consistency_score")
  emergencyFundScore      Int      @map("emergency_fund_score")
  breakdownJson           Json     @map("breakdown_json")
  createdAt               DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@map("financial_health_scores")
}

model ChatHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  role         ChatRole
  message      String
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_history")
}

// ─── Social / Family ──────────────────────────────────────────────────────────

model FamilyGroup {
  id          String   @id @default(uuid())
  name        String
  createdById String   @map("created_by")
  inviteCode  String   @unique @map("invite_code")
  createdAt   DateTime @default(now()) @map("created_at")

  creator User           @relation(fields: [createdById], references: [id])
  members FamilyMember[]

  @@map("family_groups")
}

model FamilyMember {
  id        String           @id @default(uuid())
  groupId   String           @map("group_id")
  userId    String           @map("user_id")
  role      FamilyMemberRole @default(member)
  joinedAt  DateTime         @default(now()) @map("joined_at")

  group FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("family_members")
}
